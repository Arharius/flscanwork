# Скопируйте в .env для локального запуска
# На Render.com задаётся через Environment Variables

# ОБЯЗАТЕЛЬНО — токен от @BotFather
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Канал для проверки подписки (уже настроено)
CHANNEL_ID=@dnorca

# Секретное слово (регистр не важен)
SECRET_WORD=хочу

# Ссылка на Яндекс.Диск (уже настроено)
DISK_LINK=https://disk.yandex.ru/d/c6M_CbirwiK2vQ

# Порт для health-check (Render выставляет автоматически)
PORT=10000

# Путь к SQLite базе
DB_PATH=/tmp/users.db
