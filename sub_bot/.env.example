# Скопируйте в .env для локального запуска

# ── VK настройки ────────────────────────────────────────────────
# Токен сообщества VK (Управление → API → Ключ доступа)
VK_TOKEN=your_vk_community_token_here

# ID сообщества VK (без минуса, число)
VK_GROUP_ID=123456789

# ── Бот-настройки ────────────────────────────────────────────────
# Username Telegram-канала (без @)
TG_CHANNEL=dnorca

# Секретное слово (регистр не важен)
SECRET_WORD=хочу

# Ссылка на Яндекс.Диск
DISK_LINK=https://disk.yandex.ru/d/c6M_CbirwiK2vQ

# ── Хостинг ──────────────────────────────────────────────────────
PORT=10000
DB_PATH=/tmp/vk_users.db
