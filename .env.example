# === LLM Configuration (OpenRouter + DeepSeek) ===
# Ключ от OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Модель DeepSeek через OpenRouter
LLM_MODEL=deepseek/deepseek-chat

# === Database (SQLite path) ===
# Note: DATABASE_URL is reserved by Replit for PostgreSQL — use SQLITE_DB instead
SQLITE_DB=jobs.db

# === Scheduling ===
# How often to run the search cycle (minutes)
SEARCH_INTERVAL_MINUTES=20

# === Filters ===
# Minimum budget to consider a job (USD)
MIN_BUDGET=50.0

# === Telegram Notifications (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Logging ===
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# === Platform API Keys (optional — used for real API mode) ===
UPWORK_CLIENT_ID=
UPWORK_CLIENT_SECRET=
UPWORK_ACCESS_TOKEN=
UPWORK_REFRESH_TOKEN=
FREELANCER_CLIENT_ID=
FREELANCER_ACCESS_TOKEN=
KWORK_USERNAME=
KWORK_PASSWORD=
# Сессионные куки Kwork (скопировать из браузера → DevTools → Storage → Cookies → kwork.ru)
# Формат: "RORSSQIHEK=abc123; csrf_user_token=xyz; userId=123456"
KWORK_SESSION_COOKIE=

# Сессионные куки FL.ru (скопировать из браузера → DevTools → Storage → Cookies → fl.ru)
# Формат: "PHPSESSID=abc; XSRF-TOKEN=xyz; id=1234567"
FL_SESSION_COOKIE=
FL_USERNAME=
FL_PASSWORD=

# === DeepSeek API (если не используется OpenRouter) ===
DEEPSEEK_API_KEY=

# === Порт веб-дашборда ===
# На Replit: оставить пустым (по умолчанию 5000)
# Для локального запуска (например, 192.168.31.216:8080):
PORT=8080
